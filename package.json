{
  "name": "chinese-practice-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --web",
    "web": "expo start --web",
    "export:web": "node scripts/export-web.js",
    "export:web:github": "node scripts/export-web.js github",
    "backend:dev": "npm --prefix backend run dev",
    "backend:test": "npm --prefix backend run test",
    "generate:hsk": "python3 fetch_hsk_3_0.py",
    "generate:pdf-deck": "python3 scripts/build_pdf_dataset_json.py",
    "generate:pinyin": "python3 generateValidPinyin.py",
    "generate:audio-assets": "python3 scripts/build_hsk_audio_asset_map.py",
    "generate:audio-sources": "python3 scripts/build_hsk_audio_sources.py",
    "refresh:data": "python3 fetch_hsk_3_0.py && python3 generateValidPinyin.py"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.10.0",
    "@react-navigation/native": "^7.1.28",
    "expo": "~54.0.31",
    "expo-asset": "~12.0.12",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.19.0",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
